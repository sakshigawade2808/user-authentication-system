<!DOCTYPE html>
<html>
<head>
    <title>Forgot Password</title>
</head>
<body>

    <h2>Forgot Password</h2>

    <form action="/forgot-password" method="POST">

        <label>Email</label><br><br>

        <input
            type="email"
            name="email"
            placeholder="Enter your registered email"
            required
        >

        <br><br>

        <button type="submit">
            Send Reset Link
        </button>

    </form>

    <br>

    <a href="/login">
        Back to Login
    </a>

</body>
</html>