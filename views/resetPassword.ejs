<!DOCTYPE html>
<html>
<head>
    <title>Reset Password</title>
</head>
<body>

    <h1>Reset Password</h1>

    <form action="" method="POST">

        <label>New Password</label><br>
        <input
            type="password"
            name="password"
            placeholder="Enter New Password"
            required
        >

        <br><br>

        <button type="submit">
            Reset Password
        </button>

    </form>

</body>
</html>